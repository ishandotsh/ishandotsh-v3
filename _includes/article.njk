---
layout: base.njk
---
<article class="article-shell {% if contentType == 'experiment' %}experiment-article{% endif %}">
  <header class="article-header">
    <div class="article-kicker">
      {% if contentType == "experiment" %}<span class="type-badge">⚡ Experiment</span>{% else %}<span>Post</span>{% endif %}
      <time datetime="{{ date | dateIso }}">{{ date | dateDisplay }}</time>
      {% if draft %}<span class="draft-badge">Draft</span>{% endif %}
    </div>
    <h1>{{ title }}</h1>
    {% if excerpt %}<p class="article-excerpt">{{ excerpt }}</p>{% endif %}
    {% if coverImage %}<img class="cover-image" src="{{ coverImage }}" alt="">{% endif %}
    {% if series %}<div class="series-label">Series: {{ series }}</div>{% endif %}
    {% if tags %}
      <div class="tag-list" aria-label="Tags">
        {% for tag in tags %}<a class="tag" href="/tags/{{ tag | slug }}/">{{ tag }}</a>{% endfor %}
      </div>
    {% endif %}
  </header>

  <div class="prose">
    {{ content | externalLinks(site.url) | safe }}
  </div>

  {% if series %}
    {% set neighbors = collections.posts | seriesNeighbors(page.url) %}
    {% if neighbors.previous or neighbors.next %}
      <nav class="series-nav" aria-label="Series navigation">
        {% if neighbors.previous %}<a href="{{ neighbors.previous.url }}">← {{ neighbors.previous.data.title }}</a>{% else %}<span></span>{% endif %}
        {% if neighbors.next %}<a href="{{ neighbors.next.url }}">{{ neighbors.next.data.title }} →</a>{% endif %}
      </nav>
    {% endif %}
  {% endif %}
</article>
