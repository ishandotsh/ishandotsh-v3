---
layout: base.njk
pagination:
  data: collections.allTags
  size: 1
  alias: tag
permalink: /tags/{{ tag | slug }}/
eleventyComputed:
  title: "Tagged {{ tag }}"
---
{% set taggedItems = collections.allContent | filterByTag(tag) %}
<section class="home-feed archive-feed">
  <header class="page-header archive-header tag-page-header">
    <p class="eyebrow">{{ taggedItems.length }} item{% if taggedItems.length != 1 %}s{% endif %}</p>
    <h1>{{ tag }}</h1>
    <p><a href="/tags/">← All tags</a></p>
  </header>
  <div class="home-feed-list">
    {% for item in taggedItems %}
      {% include "feed-list-item.njk" %}
    {% else %}
      <p class="muted">No items for this tag.</p>
    {% endfor %}
  </div>
</section>
