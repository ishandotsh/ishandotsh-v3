---
layout: base.njk
title: Home
---
<section class="home-feed">
  <div class="home-tag-cloud" aria-label="Browse by tag">
    <a class="home-tag-chip home-tag-all" href="/tags/">all</a>
    {% for tag in collections.allTags %}
      <a class="home-tag-chip" href="/tags/{{ tag | slug }}/">{{ tag }}</a>
    {% endfor %}
    <a class="home-tag-search" href="/search/" aria-label="Search">
      <span aria-hidden="true">⌕</span> Search
    </a>
  </div>

  <div class="home-feed-heading">
    <h2>Writing</h2>
    <a class="home-rss-link" href="/feed.xml" aria-label="RSS feed">RSS</a>
  </div>

  <div class="home-feed-list">
    {% for item in collections.allContent %}
      {% include "feed-list-item.njk" %}
    {% else %}
      <p class="muted">No posts or experiments yet.</p>
    {% endfor %}
  </div>
</section>
